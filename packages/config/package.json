{
  "name": "@marchen-spec/config",
  "version": "0.7.1",
  "private": true,
  "description": "Configuration utilities for MarchenSpec",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate-templates.ts",
    "build": "pnpm generate && tsdown --config tsdown.config.ts",
    "dev": "pnpm generate && tsdown --config tsdown.config.ts --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@marchen-spec/shared": "workspace:*"
  }
}
